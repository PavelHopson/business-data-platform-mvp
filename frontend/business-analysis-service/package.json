{
  "name": "business-analysis-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NEXT_TELEMETRY_DISABLED=1 next dev",
    "build": "cross-env NEXT_TELEMETRY_DISABLED=1 NODE_OPTIONS=--max-old-space-size=4096 next build",
    "build:fast": "cross-env NEXT_TELEMETRY_DISABLED=1 NODE_OPTIONS=--max-old-space-size=4096 next build --no-lint",
    "start": "next start",
    "lint": "next lint",
    "lint:ci": "node lint-ci.js",
    "type-check": "tsc --noEmit --incremental",
    "test": "jest",
    "clean": "rimraf .next out dist",
    "prebuild": "npm run clean"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@types/d3": "^7.4.3",
    "@types/styled-components": "^5.1.34",
    "autoprefixer": "^10.0.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "lucide-react": "^0.445.0",
    "next": "^14.2.14",
    "postcss": "^8",
    "react": "^18",
    "react-dom": "^18",
    "styled-components": "^6.1.19",
    "tailwind-merge": "^2.5.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.8",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "cross-env": "^7.0.3",
    "eslint": "^8",
    "eslint-config-next": "^14.2.14",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rimraf": "^5.0.10"
  }
}
